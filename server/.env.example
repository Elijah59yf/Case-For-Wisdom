# Which DB adapter to load. mariadb (local dev) | supabase (production)
DB_ADAPTER=mariadb

# MariaDB (local)
DB_HOST=localhost
DB_PORT=3306
DB_USER=elijah
DB_PASS=
DB_NAME=caseforwisdom

# Supabase (production)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Auth
JWT_SECRET=change-me-in-prod
# Short-lived access token (8h per session).
JWT_EXPIRES_IN=8h
# Separate secret for the long-lived refresh token. MUST differ from JWT_SECRET.
JWT_REFRESH_SECRET=another-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Uploads. local (filesystem) | supabase (storage)
UPLOAD_ADAPTER=local
UPLOAD_DIR=./uploads

# Server
PORT=3000

# Email (transactional ticketing) — cascading failover: resend → brevo
RESEND_API_KEY=
BREVO_API_KEY=
EMAIL_FROM=tickets@acaseforwisdom.com
EMAIL_FROM_NAME=A Case for Wisdom

# Public site origin — used to build ticket URLs in registration replies
FRONTEND_URL=http://127.0.0.1:5500
